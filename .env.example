# Require confirmed=true on mutation tools (default: true)
MCP_STRICT_WRITES=true
LOG_LEVEL=INFO

# RAG (local vector DB + embeddings)
KNOWLEDGE_DIR=knowledge/chunks
RAG_TOP_K=5
RAG_VECTOR_TOP_N=20
RAG_VECTOR_DB_DIR=.rag_db
RAG_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2


# Trimble Model Gateway (development)
TRIMBLE_MODEL_GATEWAY_URL=https://models.dev.trimble-ai.com
TRIMBLE_MODEL=claude-4.5-sonnet
TRIMBLE_MAX_TOKENS=4096

# Trimble ID access token for Model Gateway (paste manually)
TID_TOKEN=

# Optional: auto-fetch token via client credentials instead of TID_TOKEN
