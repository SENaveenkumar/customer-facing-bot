# DXP GraphQL endpoint
DXP_GRAPHQL_URL=http://localhost:5000/graphql

# Bearer token for API calls (dealer JWT with DXP scope)
DXP_BEARER_TOKEN=

# Dealer CDH account id for dxp-Account-Ids header (required for authorization)
DXP_ACCOUNT_IDS=

# Require confirmed=true on mutation tools (default: true)
MCP_STRICT_WRITES=true

# Optional: OpenAI-compatible API for chat CLI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
